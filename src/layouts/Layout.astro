---
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import MistBackground from "@/components/MistBackground.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Still wild nature</title>
  </head>
  <body>
    <div id="wrapper">
      <MistBackground />
      <div id="content">
        <Nav lang="en" />
        <slot />
        <Footer />
      </div>
    </div>

    <script type="module">
      import gsap from "https://cdn.skypack.dev/gsap@3.13.0";
      import ScrollTrigger from "https://cdn.skypack.dev/gsap@3.13.0/ScrollTrigger";
      import ScrollSmoother from "https://cdn.skypack.dev/gsap@3.13.0/ScrollSmoother";

      gsap.registerPlugin(ScrollTrigger, ScrollSmoother);

      ScrollSmoother.create({
        wrapper: "#wrapper",
        content: "#content",
        smooth: 2,
        speed: 1.2,
        effects: true
      });
    </script>
  </body>
</html>

<style is:global>
  @import "tailwindcss";

  @theme {
    --animate-bounce-pulse: bounce-pulse 2s ease-in-out infinite;
  }

  @keyframes bounce-pulse {
    0% {
      transform: translateY(0);
      scale: 0.8;
      opacity: 0.8;
    }

    50% {
      transform: translateY(-5px);
      opacity: 1;
      scale: 1;
    }

    100% {
      transform: translateY(0);
      scale: 0.8;
      opacity: 0.8;
    }
  }

  html,
  body {
    background: #0B0F0C;
    min-height: 300vh;
    overflow-x: hidden;
    overscroll-behavior-y: auto;
    color: white;
    margin: 0;
    width: 100%;
  }
</style>