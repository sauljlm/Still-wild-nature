---
import SmalGroupsIcon from "./icons/SmalGroupsIcon.astro";
import LocalExperienceIcon from "./icons/LocalExperienceIcon.astro";
import NatureCareIcon from "./icons/NatureCareIcon.astro";

const { title, description, icon } = Astro.props;

const iconMap = {
  smalGroup: SmalGroupsIcon,
  localExperience: LocalExperienceIcon,
  natureCare: NatureCareIcon,
};

const IconComponent = iconMap[icon];
---

<article class="h-full">
  <div class="rounded-2xl h-full bg-black shadow-lg p-6 md:p-8 flex flex-col items-center transition-all duration-300 hover:-translate-y-3 hover:shadow-xl">
    
    <div class="w-[60px] h-[60px]">
      {IconComponent && <IconComponent color="#FE792A" class="w-full h-full text-[#FE792A] hover:text-[#FF6434] transition" />}
    </div>

    <h4 class="text-xl font-semibold mt-6 mb-3">{title}</h4>

    <p class="text-gray-400 text-center">
      {description}
    </p>

  </div>
</article>