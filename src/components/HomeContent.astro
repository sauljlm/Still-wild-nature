---
import Gallery from "@/components/Gallery.astro";
import TourCard from "@/components/TourCard.astro";
import AboutUsCard from "@/components/AboutUsCard.astro";
import Reviews from "@/components/Reviews.astro";
import toursByLang from "@/data/tours.json";
import aboutUsByLang from "@/data/aboutUs.json";
import { getTranslations } from "@/i18n/translations";

const { lang = "en" } = Astro.props;
const t = getTranslations(lang);
const aboutUs = aboutUsByLang[lang] ?? aboutUsByLang.es;

const GALLERY_IMAGES = Array.from({ length: 16 }, (_, i) => `/images/gallery/img${i + 1}.webp`);

function shuffle(array) {
  const copy = [...array];
  for (let i = copy.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [copy[i], copy[j]] = [copy[j], copy[i]];
  }
  return copy;
}

// Each tour card gets 3 random gallery photos to use as a slider, instead of
// the single repeated placeholder image every tour previously shared.
const tours = (toursByLang[lang] ?? toursByLang.es).map((tour) => ({
  ...tour,
  images: shuffle(GALLERY_IMAGES).slice(0, 3),
}));
---

<section class="banner-video relative">
  <div class="bg-video">
    <video autoplay muted loop preload="none" >
      <source src="/videos/forest.mp4" type="video/mp4" />
      Tu navegador no soporta el elemento de video.
    </video>
  </div>
  <div class="absolute top-0 w-full h-full z-2 flex flex-col justify-center items-center">
    <div class="w-[90%] xl:w-[70%]">
      <h1 id="hero-title" class="text-3xl md:text-6xl text-bold">{t.hero.title}</h1>
      <h2 id="hero-subtitle" class="text-l md:text-xl">{t.hero.subtitle}</h2>
    </div>
  </div>
</section>

<div class="relative flex flex-col items-center">
    <section id="tours" class="w-[90%] xl:w-[80%] mt-24 md:mt-10 mx-auto">
      <div class="flex flex-col justify-between mb-30 gap-6">
        <div class="tours-head w-full flex items-center flex-col">
          <h3 class="tracking-wide text-lg md:text-2xl">
            {t.tours.label}
          </h3>

          <h2 class="text-2xl md:text-4xl font-bold mt-2 text-center">
            {t.tours.heading}
          </h2>
        </div>
      </div>

      <div class="tours">
        {tours.map((tour, index) => (
          <TourCard
            tour={tour}
            reverse={index % 2 !== 0}
            lang={lang}
          />
        ))}
      </div>
    </section>

    <section id="why-us" class="w-[90%] xl:w-[65%] mt-24 md:mt-32 mx-auto">
      <div class="why-us-head flex flex-col justify-between mb-12 gap-6">
        <div class="w-full flex items-center flex-col">
          <h3 class="text-lg md:text-2xl tracking-wide">
            {t.whyUs.label}
          </h3>
          <h2 class="text-2xl md:text-4xl font-bold mt-2 text-center">
            {t.whyUs.heading}
          </h2>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {aboutUs.map((item) => (
          <AboutUsCard
            title={item.title}
            description={item.description}
            icon={item.icon}
          />
        ))}
      </div>

      <div class="flex flex-col md:flex-row items-center mt-12 md:mt-20 gap-10 md:gap-0">
        <div class="w-full md:w-1/2 md:pr-16 order-2 md:order-1">
          <h4 class="text-2xl md:text-3xl font-bold text-[#4E7C59]">
            {t.whyUs.guideName}
          </h4>
          <p class="pt-6 md:pt-10 text-base md:text-lg">
            {t.whyUs.guideBio1}
          </p>
          <p class="pt-4 md:pt-5 text-base md:text-lg">
            {t.whyUs.guideBio2}
          </p>
        </div>
        <div class="w-full md:w-1/2 guide-wrapper order-1 md:order-2">
          <img class="guide" src="/images/aboutMe.png" alt="">
        </div>
      </div>
    </section>
    <section id="customer-experiences" class="w-[90%] xl:w-[65%]">
      <h2 class="text-2xl md:text-4xl mt-20 w-full text-center">
        {t.customerExperiences.heading}
      </h2>
      <Reviews lang={lang} />
    </section>

    <section id="gallery" class="gallery py-32 w-[90%] ">
      <Gallery />
    </section>
  </div>

<style>
  .bg-video {
    position: relative;
    top: 0;
    left: 0;
    width: 100%;
    height: 92vh;
    object-fit: cover;
    z-index: 1;
  }
  .bg-video video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .bg-video::before {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.3);
    z-index: 1;
  }

  .guide-wrapper {
    position: relative;
    height: 500px;
    overflow: hidden;
  }

  @media (min-width: 1024px) {
    .guide-wrapper {
      height: 600px;
    }
  }

  @media (min-width: 768px) {
    .guide-wrapper {
      height: 700px;
    }

    .bg-video {
      height: 100vh;
    }
  }

  .guide {
      position: absolute;
      width: 100%;
      height: 120%;
      object-fit: cover;
      top: -10%;
      left: 0;
      will-change: transform;
  }
</style>

<script>
  import { gsap } from "gsap"
  import { ScrollTrigger } from "gsap/ScrollTrigger"
  import { SplitText } from "gsap/SplitText"

  gsap.registerPlugin(ScrollTrigger, SplitText);

  const title = document.querySelector("#hero-title");
  const subtitle = document.querySelector("#hero-subtitle");
  const toursHead = document.querySelector(".tours-head");
  const whyUsHead = document.querySelector(".why-us-head");

  let titleSplit: SplitText | undefined;
  let subtitleSplit: SplitText | undefined;

  function initAnimation() {
    titleSplit?.revert();
    subtitleSplit?.revert();

    titleSplit = new SplitText(title, { type: "words" });
    subtitleSplit = new SplitText(subtitle, { type: "words" });

    const tl = gsap.timeline({ ease: "power2.out" });

    tl.from(titleSplit.words, {
      duration: 0.3,
      y: 35,
      stagger: 0.1
    })
    .from(titleSplit.words, {
      duration: 0.3,
      autoAlpha: 0,
      stagger: 0.1,
      filter: "blur(3px)"
    }, 0.2)
    .from(subtitleSplit.words, {
      duration: 0.3,
      y: 20,
      autoAlpha: 0,
      stagger: 0.05
    }, "-=0.2");
  }

  initAnimation();

  window.addEventListener("load", () => {

    gsap.from(toursHead, {
      y: 50,
      autoAlpha: 0,
      duration: 1,
      ease: "power2.out",
      scrollTrigger: {
        trigger: toursHead,
        start: "top 80%"
      }
    });

    gsap.from(whyUsHead, {
        y: 50,
        autoAlpha: 0,
        duration: 1,
        ease: "power2.out",
        scrollTrigger: {
          trigger: whyUsHead,
          start: "top 80%"
        }
    });

    gsap.utils.toArray(".parallax-wrapper").forEach((wrapper) => {

      const image = wrapper.querySelector(".parallax-image")
      if (!image) return

      gsap.fromTo(
        image,
        { yPercent: -20 },
        {
          yPercent: 30,
          ease: "none",
          scrollTrigger: {
            trigger: wrapper,
            start: "top 140%",
            end: "bottom -20%",
            scrub: 2
          }
        }
      )
      ScrollTrigger.refresh(true)
    })

    gsap.utils.toArray(".guide-wrapper").forEach((wrapper) => {
      const image = wrapper.querySelector(".guide")
      if (!image) return

      gsap.to(
        image,
        {
          yPercent: 30,
          ease: "none",
          scrollTrigger: {
            trigger: wrapper,
            start: "top 200%",
            end: "bottom top",
            scrub: 2,
          }
        }
      )
      ScrollTrigger.refresh(true)
    })

    gsap.utils.toArray(".tour-card").forEach((card) => {

      const image = card.querySelector(".image-anim")
      const text = card.querySelector(".text-anim")

      if (!image || !text) return

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: card,
          start: "top bottom",
          toggleActions: "play none none none"
        }
      })

      tl.from(image, {
        y: 80,
        autoAlpha: 0,
        duration: 1,
        ease: "power2.out"
      })
      .from(text, {
        y: 40,
        autoAlpha: 0,
        duration: 1,
        ease: "power2.out"
      }, "-=0.6")

    })

    gsap.set(".why-us-card", {
      y: 50,
      autoAlpha: 0
    });

    ScrollTrigger.batch(".why-us-card", {
      start: "top 85%",
      onEnter: (batch) =>
        gsap.to(batch, {
          y: 0,
          autoAlpha: 1,
          duration: 0.8,
          ease: "power2.out",
          stagger: 0.2,
        }),
      once: true,
    });
  })

</script>
