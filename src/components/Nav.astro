---
import Button from "./Button.astro";
import { getTranslations } from "@/i18n/translations";

const { lang = "es" } = Astro.props;

const isEnglish = lang === "en";
const basePath = isEnglish ? "/en" : "/";
const t = getTranslations(lang);

const navigation = [
  { title: t.nav.tours, path: "#tours" },
  { title: t.nav.whyUs, path: "#why-us" },
  { title: t.nav.customerExperiences, path: "#customer-experiences" },
  { title: t.nav.gallery, path: "#gallery" },
];

const contactUrl = isEnglish
  ? "https://wa.me/50686654446?text=Hello"
  : "https://wa.me/50686654446?text=Hola";
---

<!-- Invisible hover strip: lets the mouse reveal the header even while it's
     slid off-screen, since the header's own hit area moves with its transform. -->
<div id="nav-hover-strip" class="fixed top-0 left-0 w-full h-3 z-40"></div>

<header id="site-header" class="fixed top-0 left-0 w-full h-22 bg-[#0B0F0C]/85 backdrop-blur-sm z-50 flex justify-center transition-transform duration-500 ease-in-out">
  <div class="w-full max-w px-6 md:max-w-5xl xl:max-w-[70%] flex items-center justify-between relative">

    <a href={basePath} class="absolute">
      <img class="w-[60px] rounded-full" src="/images/still-wild-nature.jpg" alt="Logo" />
    </a>

    <button
      id="menu-btn"
      class="ml-auto lg:hidden flex flex-col gap-1 z-2 md:z-1"
      aria-label="Toggle Menu"
    >
      <span class="line line-1 block h-0.5 w-6 bg-white transition-all duration-300"></span>
      <span class="line line-2 block h-0.5 w-6 bg-white transition-all duration-300"></span>
      <span class="line line-3 block h-0.5 w-6 bg-white transition-all duration-300"></span>
    </button>

    <nav
      id="mobile-menu"
      class="absolute lg:static top-0 left-full w-full
             bg-[#414a47] lg:bg-transparent
             px-6 lg:px-0 h-[90vh] lg:h-16
             flex flex-col lg:flex-row
             justify-between items-center
             transition-all duration-300"
    >
      <ul class="w-full flex ml-auto mr-auto flex-col items-center mt-20 md:mt-0 h-1/3 justify-between lg:flex-row lg:justify-between lg:w-6/12 xl:w-6/12 lg:py-0">
        {navigation.map((item) => (
          <li>
            <a
              href={item.path}
              class="border-b-4 border-transparent px-4 md:p-0 rounded-lg md:rounded-none active:text-black md:active:text-white active:bg-white md:active:bg-transparent md:hover:border-white transition text-lg md:text-base transition-all duration-300 ease-in-out"
            >
              {item.title}
            </a>
          </li>
        ))}
      </ul>

      <div class="flex gap-2">
        <a
          href={isEnglish ? "/" : "/en"}
          class="flex items-center gap-2 text-white font-medium hover:bg-[#323232] px-3 py-2 rounded-md transition-all duration-300"
          aria-label={t.nav.switchLanguage}
        >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className="lucide lucide-globe w-5 h-5">
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"></path>
                <path d="M2 12h20"></path>
            </svg>
          <span class="text-lg">{isEnglish ? "ES" : "EN"}</span>
        </a>

        <Button variant="primary">
          <a href={contactUrl} target="_blank">
            {t.nav.contactUs}
          </a>
        </Button>
      </div>
    </nav>
  </div>
</header>

<script>
  import { ScrollSmoother } from "gsap/ScrollSmoother";

  const btn = document.getElementById("menu-btn");
  const menu = document.getElementById("mobile-menu");

  const line1 = btn?.querySelector(".line-1");
  const line2 = btn?.querySelector(".line-2");
  const line3 = btn?.querySelector(".line-3");

  btn?.addEventListener("click", () => {
    line1.classList.toggle("rotate-45");
    line1.classList.toggle("translate-y-1.5");

    line2.classList.toggle("opacity-0");

    line3.classList.toggle("-rotate-45");
    line3.classList.toggle("-translate-y-1.5");
    if (menu.classList.contains("left-full")) {
      menu.classList.remove("left-full");
      menu.classList.add("left-0");
    } else {
      menu.classList.remove("left-0");
      menu.classList.add("left-full");
    }
  });

  // The page scrolls via GSAP ScrollSmoother (a transform on #content, not
  // real window scroll). A native "#anchor" jump moves the browser's real
  // scroll position without telling ScrollSmoother, so the two desync and
  // everything above the target renders in the wrong place. Route in-page
  // anchor clicks through ScrollSmoother's own scrollTo instead.
  document.querySelectorAll('a[href^="#"]').forEach((link) => {
    link.addEventListener("click", (e) => {
      const id = link.getAttribute("href");
      const target = id && document.querySelector(id);
      if (!target) return;

      e.preventDefault();
      menu?.classList.remove("left-0");
      menu?.classList.add("left-full");

      const smoother = ScrollSmoother.get();
      if (smoother) {
        smoother.scrollTo(target, true, "top center");
      } else {
        target.scrollIntoView({ behavior: "smooth", block: "center" });
      }
      history.pushState(null, "", id);
    });
  });

  // Auto-hide header: slides up out of view when scrolling down, slides back
  // down when scrolling up, when the mouse hovers near the top of the page,
  // or while the hero banner is still on screen.
  const header = document.getElementById("site-header");
  const hoverStrip = document.getElementById("nav-hover-strip");
  const banner = document.querySelector(".banner-video");

  let lastScrollY = window.scrollY;
  let headerHidden = false;

  const setHeaderHidden = (hidden) => {
    if (hidden === headerHidden || !header) return;
    headerHidden = hidden;
    header.style.transform = hidden ? "translateY(-100%)" : "translateY(0)";
  };

  const inBanner = () => {
    if (!banner) return window.scrollY < window.innerHeight;
    return banner.getBoundingClientRect().bottom > 0;
  };

  window.addEventListener("scroll", () => {
    const y = window.scrollY;
    const delta = y - lastScrollY;
    const mobileMenuOpen = menu?.classList.contains("left-0");

    if (mobileMenuOpen || inBanner()) {
      setHeaderHidden(false);
    } else if (delta > 2) {
      setHeaderHidden(true);
    } else if (delta < -2) {
      setHeaderHidden(false);
    }

    lastScrollY = y;
  }, { passive: true });

  header?.addEventListener("mouseenter", () => setHeaderHidden(false));
  hoverStrip?.addEventListener("mouseenter", () => setHeaderHidden(false));
</script>