            <img class="w-[75px] mb-5 md:mb-0 md:w-[100px] xl:w-[150px] rounded-full mr-5" src="/images/still-wild-nature.jpg" alt="Logo" />
            <div class="flex flex-col">
                <span class="text-xl md:text-3xl font-bold mr-2 pb-1">still_wild_nature</span>
                <span class="">Dauner98</span>
            </div>
        </div>
        <div class="w-1/6 justify-between hidden md:flex">
            <div class="flex flex-col items-center">
                <span class="font-bold text-xl">32</span>
